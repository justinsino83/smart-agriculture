<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.weiming.smartag.mapper.IrrigationTaskMapper">
    
    <select id="selectByDeviceId" resultType="com.weiming.smartag.entity.IrrigationTask">
        SELECT * FROM irrigation_task WHERE device_id = #{deviceId} ORDER BY create_time DESC LIMIT 1
    </select>
    
</mapper>
